<% provide(:title, 'All users') %>
<h1>All users</h1>

<% if current_user.admin? %>
  <div class="users-csv-export">
    <%= link_to "Export CSV", users_path(format: :csv), class: "btn btn-primary" %>
  </div>
<% end %>

<%= will_paginate %>

<ul class="users">
  <% @users.each do |user| %>
    <%= render @users %>
  <% end %>
</ul>

<%= will_paginate %>
